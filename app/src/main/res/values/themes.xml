<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.CurveDelivery" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:statusBarColor">@color/white</item>

        <item name="android:state_hovered">@android:color/transparent</item>
        <item name="android:windowDisablePreview">true</item>

        <item name="android:windowIsTranslucent">true</item>
    </style>

    <style name="CustomDatePicker" parent="Theme.AppCompat.Light.Dialog">
        <item name="colorPrimary">@color/teal_200</item>
        <item name="colorAccent">@color/teal_700</item>
        <item name="android:textColorPrimary">@color/black</item>
    </style>
</resources>